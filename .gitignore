.AutoCar-DigitalTwin/
.AutoCar-Front/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/
