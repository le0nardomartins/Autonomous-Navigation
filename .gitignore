videos/*.mp4
videos/*.avi
videos/*.mov
videos/*.mkv
videos/*.webm
!videos/.gitkeep

# ── Output gerado automaticamente ────────────────────────────────────────────
output/*.jpg
output/*.jpeg
output/*.png
output/*.json
!output/.gitkeep

